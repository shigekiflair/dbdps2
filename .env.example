# Vercel PostgresをNeon経由で作成すると自動で払い出される接続文字列
# Vercelダッシュボード > Storage > (作成したDB) > .env.local タブからコピー
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Sentry（エラー監視）
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Auth.js
# AUTH_SECRET: `npx auth secret` で生成、または任意のランダム文字列
AUTH_SECRET=""

# Twitch Developer Console (https://dev.twitch.tv/console/apps) で発行
# OAuth Redirect URL: http://localhost:3043/api/auth/callback/twitch
AUTH_TWITCH_ID=""
AUTH_TWITCH_SECRET=""

# Google Cloud Console (https://console.cloud.google.com/apis/credentials) で発行
# 承認済みリダイレクトURI: http://localhost:3043/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
